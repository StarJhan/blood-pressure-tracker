<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>血壓健康記錄</title>
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="血壓記錄">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { -webkit-tap-highlight-color: transparent; }
    </style>
</head>
<body class="bg-gray-50 text-gray-800 antialiased pb-10">

    <div class="bg-indigo-600 text-white pt-12 pb-6 px-4 text-center shadow-md sticky top-0 z-50">
        <h1 class="text-xl font-bold tracking-wide">血壓隨手記</h1>
        <p class="text-xs text-indigo-200 mt-1">專為 iPhone 設計的健康看板</p>
    </div>

    <div class="max-w-md mx-auto px-4 mt-4 space-y-6">
        
        <div class="bg-blue-50 border-l-4 border-blue-500 p-3 rounded-r shadow-sm">
            <div class="flex">
                <div class="flex-shrink-0">💡</div>
                <div class="ml-2">
                    <p class="text-xs font-semibold text-blue-800">量測溫馨提醒</p>
                    <p class="text-xs text-blue-700 mt-0.5">請靜坐5分鐘、雙腳平放不交叉。量前30分鐘請勿飲用咖啡或激烈運動。</p>
                </div>
            </div>
        </div>

        <div class="bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
            <h2 class="text-base font-bold text-gray-700 mb-4 flex items-center">📝 新增量測紀錄</h2>
            <form id="bpForm" class="space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-medium text-gray-500 mb-1">收縮壓 (高壓)</label>
                        <input type="number" inputmode="numeric" id="sys" required placeholder="mmHg" 
                            class="w-full bg-gray-50 border border-gray-200 rounded-xl p-3 text-center text-lg font-semibold focus:outline-none focus:ring-2 focus:ring-indigo-500">
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-500 mb-1">舒張壓 (低壓)</label>
                        <input type="number" inputmode="numeric" id="dia" required placeholder="mmHg" 
                            class="w-full bg-gray-50 border border-gray-200 rounded-xl p-3 text-center text-lg font-semibold focus:outline-none focus:ring-2 focus:ring-indigo-500">
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">脈搏 (心跳)</label>
                    <input type="number" inputmode="numeric" id="pulse" required placeholder="bpm" 
                        class="w-full bg-gray-50 border border-gray-200 rounded-xl p-3 text-center text-lg font-semibold focus:outline-none focus:ring-2 focus:ring-indigo-500">
                </div>

                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">備註標籤 (選填)</label>
                    <div class="flex flex-wrap gap-2 mt-1" id="tagContainer">
                        <button type="button" onclick="toggleTag(this)" class="tag-btn bg-gray-100 text-gray-600 text-xs px-3 py-1.5 rounded-full border border-gray-200">#剛起床</button>
                        <button type="button" onclick="toggleTag(this)" class="tag-btn bg-gray-100 text-gray-600 text-xs px-3 py-1.5 rounded-full border border-gray-200">#睡前</button>
                        <button type="button" onclick="toggleTag(this)" class="tag-btn bg-gray-100 text-gray-600 text-xs px-3 py-1.5 rounded-full border border-gray-200">#吃藥前</button>
                        <button type="button" onclick="toggleTag(this)" class="tag-btn bg-gray-100 text-gray-600 text-xs px-3 py-1.5 rounded-full border border-gray-200">#感覺頭暈</button>
                    </div>
                </div>

                <button type="submit" class="w-full bg-indigo-600 text-white font-semibold py-3 rounded-xl shadow-md hover:bg-indigo-700 active:scale-[0.98] transition-all text-sm mt-2">
                    儲存紀錄
                </button>
            </form>
        </div>

        <div id="statusAlert" class="hidden p-4 rounded-2xl shadow-sm border text-center transition-all">
            <p id="statusTitle" class="font-bold text-lg"></p>
            <p id="statusDesc" class="text-xs mt-1 text-gray-600"></p>
        </div>

        <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100">
            <h2 class="text-base font-bold text-gray-700 mb-3">📈 近期血壓趨勢</h2>
            <div class="relative w-full h-48">
                <canvas id="bpChart"></canvas>
            </div>
        </div>

        <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100">
            <div class="flex justify-between items-center mb-3">
                <h2 class="text-base font-bold text-gray-700">📋 歷史紀錄</h2>
                <div class="flex space-x-2">
                    <button onclick="exportCSV()" class="text-xs text-indigo-600 bg-indigo-50 px-2 py-1 rounded">匯出</button>
                    <button onclick="clearData()" class="text-xs text-red-500 bg-red-50 px-2 py-1 rounded">清空</button>
                </div>
            </div>
            <div class="flow-root max-h-60 overflow-y-auto divide-y divide-gray-100" id="historyList">
                <p class="text-center text-gray-400 py-4 text-xs">尚無量測數據</p>
            </div>
        </div>
    </div>

    <script>
        let bpData = JSON.parse(localStorage.getItem('bpRecords')) || [];
        let bpChart = null;

        document.getElementById('bpForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const sys = parseInt(document.getElementById('sys').value);
            const dia = parseInt(document.getElementById('dia').value);
            const pulse = parseInt(document.getElementById('pulse').value);
            
            // 收集選中的標籤
            const activeTags = [];
            document.querySelectorAll('.tag-btn.bg-indigo-600').forEach(btn => activeTags.push(btn.innerText));

            const newRecord = {
                id: Date.now(),
                date: new Date().toLocaleString('zh-TW', { month: 'numeric', day: 'numeric', hour: '2-digit', minute: '2-digit' }),
                sys: sys,
                dia: dia,
                pulse: pulse,
                tags: activeTags.join(' ')
            };

            bpData.unshift(newRecord);
            localStorage.setItem('bpRecords', JSON.stringify(bpData));

            // 更新畫面與判定高低
            evaluateBP(sys, dia);
            updateUI();
            
            // 重設表單與標籤
            this.reset();
            document.querySelectorAll('.tag-btn').forEach(btn => {
                btn.className = "tag-btn bg-gray-100 text-gray-600 text-xs px-3 py-1.5 rounded-full border border-gray-200";
            });
        });

        function toggleTag(btn) {
            if (btn.classList.contains('bg-indigo-600')) {
                btn.className = "tag-btn bg-gray-100 text-gray-600 text-xs px-3 py-1.5 rounded-full border border-gray-200";
            } else {
                btn.className = "tag-btn bg-indigo-600 text-white text-xs px-3 py-1.5 rounded-full border border-indigo-600 shadow-sm";
            }
        }

        function evaluateBP(sys, dia) {
            const alertBox = document.getElementById('statusAlert');
            const title = document.getElementById('statusTitle');
            const desc = document.getElementById('statusDesc');
            alertBox.classList.remove('hidden');

            if (sys < 120 && dia < 80) {
                alertBox.className = "p-4 rounded-2xl shadow-sm border border-green-200 bg-green-50 text-green-800 text-center animate-pulse";
                title.innerText = "🟢 血壓正常";
                desc.innerText = "數值相當棒！請繼續保持均衡飲食與規律運動。";
            } else if (sys >= 140 || dia >= 90) {
                alertBox.className = "p-4 rounded-2xl shadow-sm border border-red-200 bg-red-50 text-red-800 text-center";
                title.innerText = "🔴 高血壓二期";
                desc.innerText = "血壓顯著偏高！請坐下休息10分鐘重測。若持續偏高或伴隨頭痛、胸悶，請遵醫囑或就醫。";
            } else if (sys >= 130 || (dia >= 80 && dia <= 89)) {
                alertBox.className = "p-4 rounded-2xl shadow-sm border border-orange-200 bg-orange-50 text-orange-800 text-center";
                title.innerText = "🟠 高血壓一期";
                desc.innerText = "血壓偏高囉，日常請減少鹽分攝取、避免熬夜，留意身體狀況。";
            } else {
                alertBox.className = "p-4 rounded-2xl shadow-sm border border-yellow-200 bg-yellow-50 text-yellow-800 text-center";
                title.innerText = "🟡 血壓偏高";
                desc.innerText = "收縮壓稍微超出正常範圍，注意作息與適度補充水分。";
            }
        }

        function updateUI() {
            // 1. 更新歷史列表
            const listContainer = document.getElementById('historyList');
            if (bpData.length === 0) {
                listContainer.innerHTML = '<p class="text-center text-gray-400 py-4 text-xs">尚無量測數據</p>';
            } else {
                listContainer.innerHTML = bpData.map(r => `
                    <div class="py-2.5 flex justify-between items-center text-sm">
                        <div>
                            <p class="text-xs text-gray-400">${r.date}</p>
                            <p class="text-xs text-indigo-600 font-medium mt-0.5">${r.tags}</p>
                        </div>
                        <div class="text-right">
                            <span class="font-bold text-gray-700 text-base">${r.sys}/${r.dia}</span>
                            <span class="text-xs text-gray-400 ml-1">脈搏 ${r.pulse}</span>
                        </div>
                    </div>
                `).join('');
            }

            // 2. 更新 Chart.js 圖表 (最多顯示最新7筆)
            const chartData = [...bpData].slice(0, 7).reverse();
            const labels = chartData.map(r => r.date.split(' ')[0]); // 只留月/日
            const sysValues = chartData.map(r => r.sys);
            const diaValues = chartData.map(r => r.dia);

            if (bpChart) bpChart.destroy();

            const ctx = document.getElementById('bpChart').getContext('2d');
            bpChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        { label: '高壓', data: sysValues, borderColor: '#ef4444', backgroundColor: 'transparent', tension: 0.2, borderWidth: 2 },
                        { label: '低壓', data: diaValues, borderColor: '#3b82f6', backgroundColor: 'transparent', tension: 0.2, borderWidth: 2 }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { labels: { boxWidth: 10, font: { size: 10 } } } },
                    scales: { y: { ticks: { font: { size: 10 } } }, x: { ticks: { font: { size: 10 } } } }
                }
            });
        }

        function exportCSV() {
            if(bpData.length === 0) return alert('沒有可導出的數據');
            let csvContent = "\uFEFF日期時間,收縮壓(高壓),舒張壓(低壓),脈搏(心跳),備註\n";
            bpData.forEach(r => {
                csvContent += `${r.date},${r.sys},${r.dia},${r.pulse},${r.tags}\n`;
            });
            const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement("a");
            link.href = URL.createObjectURL(blob);
            link.setAttribute("download", `血壓歷史紀錄_${new Date().toLocaleDateString()}.csv`);
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }

        function clearData() {
            if (confirm('確定要清空所有存在手機本機的血壓紀錄嗎？（建議清空前先點選匯出備份）')) {
                bpData = [];
                localStorage.removeItem('bpRecords');
                document.getElementById('statusAlert').classList.add('hidden');
                updateUI();
            }
        }

        // 初始化
        updateUI();
    </script>
</body>
</html>
